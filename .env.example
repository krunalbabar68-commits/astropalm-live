# ============================================
# AI PALM READER - ENVIRONMENT CONFIGURATION
# ============================================
# 
# INSTRUCTIONS:
# 1. Copy this file and rename to: .env
# 2. Replace placeholder values with your actual API keys
# 3. NEVER commit .env file to version control
# 4. Keep this .env.example as a template
#
# ============================================

# --------------------------------------------
# OPENROUTER API CONFIGURATION
# --------------------------------------------
# Get your API key from: https://openrouter.ai/keys
# This key is used for all AI-powered features:
# - Palm reading analysis (Vision model)
# - Tarot interpretations (Reasoning model)
# - Horoscope generation (Reasoning model)
# - Daily guidance (Reasoning model)
# - AI chat responses (Reasoning model)

VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here

# --------------------------------------------
# APP CONFIGURATION (OPTIONAL)
# --------------------------------------------
# These are optional configurations for customization

# App Environment: development | staging | production
VITE_APP_ENV=production

# Enable/disable analytics (true | false)
VITE_ENABLE_ANALYTICS=false

# Debug mode (true | false) - Set to false in production
VITE_DEBUG_MODE=false

# --------------------------------------------
# AI MODEL CONFIGURATION
# --------------------------------------------
# These are the default models used by the app
# Only change if you know what you're doing

# Vision model for palm image analysis
VITE_VISION_MODEL=allenai/molmo-7b-d-0924

# Reasoning model for text generation
VITE_REASONING_MODEL=meta-llama/llama-3.2-3b-instruct:free

# --------------------------------------------
# FEATURE FLAGS (OPTIONAL)
# --------------------------------------------
# Enable or disable specific features

VITE_FEATURE_PALM_SCAN=true
VITE_FEATURE_TAROT=true
VITE_FEATURE_HOROSCOPE=true
VITE_FEATURE_DAILY_GUIDANCE=true
VITE_FEATURE_LOVE_READING=true
VITE_FEATURE_AI_CHAT=true
